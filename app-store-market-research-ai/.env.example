# データベース
DATABASE_URL="file:./dev.db"

# LLM APIキー（いずれか1つ以上を設定。未設定でも簡易分析にフォールバックして動作する）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 使用する分析モデル（openai | claude | gemini）。未設定の場合は設定済みのキーから自動判定する
LLM_PROVIDER=

# デフォルト設定
DEFAULT_STOREFRONT=jp
DEFAULT_LANG=ja_jp

# キャッシュ時間（分）
RANKING_CACHE_MINUTES=60
LOOKUP_CACHE_MINUTES=1440
